{
  "name": "postits-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "tsc --noEmit -p packages/core/tsconfig.json",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.0",
    "jsdom": "^25.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "patch-package": "^8.0.1"
  }
}
